---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { getPostStats } from "../lib/post-stats";

const navItems = ["Blog", "Projects", "About"];

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    date: post.data.pubDate.toLocaleDateString("en-US", {
      month: "short",
      day: "2-digit",
      year: "numeric"
    }),
    href: `/blog/${post.id}/`,
    stats: getPostStats(post),
    title: post.data.title
  }));

const projects = [
  "Personal Website",
  "Blog Index",
  "Notes Archive"
];

const socials = [
];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Watson's life" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Watsonnn Life</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Homepage">Watson's Notes</a>
      <nav id="site-nav" class="site-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={`#${item.toLowerCase()}`}>{item}</a>
          ))
        }
      </nav>
      <div class="header-actions">
        <button class="theme-button" type="button" aria-label="Toggle theme">Toggle Theme</button>
        <button class="menu-button" type="button" aria-expanded="false" aria-controls="site-nav">
          Menu
        </button>
      </div>
    </header>

    <main class="page-shell">
      <section class="profile" id="about" aria-labelledby="profile-title" data-reveal>
        <div class="avatar-stack" aria-hidden="true">
          <div class="cover-visual"></div>
          <div class="avatar">SW</div>
        </div>
        <div>
          <p class="eyebrow">Shanghai / Texas</p>
          <h1 id="profile-title">Watson</h1>
          <p class="handle">@watsonnn.life</p>
          <p class="summary">
            写代码、整理笔记，也记录一些关于产品、设计和日常工具的想法。
            这个站点会保持轻量，重点放在内容和长期维护。
          </p>
          <a class="about-link" href="#education">About me</a>
        </div>
      </section>

      <p class="quote" data-reveal>Never stop building small things.</p>

      <section class="content-section" id="blog" aria-labelledby="posts-title" data-reveal>
        <div class="section-heading">
          <h2 id="posts-title">Posts</h2>
          <a href="#blog">More posts</a>
        </div>
        <ol class="post-list">
          {
            posts.map((post) => (
              <li>
                <a href={post.href}>
                  <time>{post.date}</time>
                  <span>
                    <strong>{post.title}</strong>
                    <small>{post.stats.label}</small>
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="content-section" id="projects" aria-labelledby="projects-title" data-reveal>
        <div class="section-heading">
          <h2 id="projects-title">Projects</h2>
        </div>
        <ul class="project-list">
          {
            projects.map((project) => (
              <li>
                <a href="#projects">{project}</a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="content-section" id="education" aria-labelledby="education-title" data-reveal>
        <div class="section-heading">
          <h2 id="education-title">Education</h2>
        </div>
        <div class="education-item">
          <h3>Professor "G" Codex / ChatGPT</h3>
          <p>Openai</p>
          <time>2024 - Present</time>
        </div>
        <div class="education-item">
          <h3>Professor "CC" Claude</h3>
          <p>Anthropic</p>
          <time>2025 - Present</time>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>© 2026</p>
      <div class="footer-links">
        {
          socials.map((link) => (
            <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined}>
              {link.label}
            </a>
          ))
        }
      </div>
    </footer>

    <script src="/src/scripts/site-motion.js"></script>
  </body>
</html>
